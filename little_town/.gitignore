# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Electron build output (electron-packager + electron-builder).
# Keep build/ tracked even though it contains generated icons — they're
# committed source-of-truth so a fresh clone has the icons without
# running the build-icon script.
release/
out/

# Generated avatar manifests — regenerated by scripts/build-manifests.js
# on each build, no reason to track them.
public/assets/character_builder/**/manifest.json
public/favicon.png

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
