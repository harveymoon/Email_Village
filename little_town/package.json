{
  "name": "town-inbox",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Town Inbox — a local-first Gmail client wrapped in a Phaser village.",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "wait-on http://localhost:5173 && cross-env TOWN_INBOX_DEV=1 electron .",
    "electron:start": "electron .",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "postinstall": "electron-builder install-app-deps"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "@types/dompurify": "^3.0.5",
    "dompurify": "^3.4.3",
    "phaser": "^4.0.0"
  }
}
