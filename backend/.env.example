# Copy this to .env (same folder) and fill in real values.
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# (Application type: Web; Authorized redirect URI: http://localhost:3091/auth/callback).

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3091/auth/callback

# Random string for signing session cookies. Generate via e.g.
# `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
SESSION_SECRET=

# Optional: override the port (default 3091)
# PORT=3091
